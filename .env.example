# Googleスプレッドシートの設定
SPREADSHEET_ID=your-spreadsheet-id-here

# サービスアカウントキーのJSONファイルへのパス（ローカル開発用）
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account-key.json

# Renderなどファイルをコミットできない環境では、上記の代わりにJSONの中身をそのまま設定する
# （設定するとGOOGLE_SERVICE_ACCOUNT_KEY_FILEより優先される）
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=

# バックエンドサーバーのポート
PORT=3001

# フロントエンドがAPIサーバーにアクセスするためのURL
VITE_API_BASE_URL=http://localhost:3001

# ログイン用JWTの署名に使う秘密鍵（十分に長いランダムな文字列を設定してください）
JWT_SECRET=change-this-to-a-long-random-string

# CORSで許可するフロントエンドのオリジン（本番環境ではデプロイ先のURLに変更してください）
CORS_ORIGIN=http://localhost:5173

# --- AIタスク細分化機能の設定 ---
# 使用するAIプロバイダー。openai / claude / gemini / dify のいずれかを指定
AI_PROVIDER=openai

# AI応答のタイムアウト時間（ミリ秒、任意・未設定時は20000）
AI_TIMEOUT_MS=20000

# OpenAIを使う場合
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Claude(Anthropic)を使う場合
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# Geminiを使う場合
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Difyを使う場合
DIFY_API_KEY=
DIFY_API_URL=https://api.dify.ai/v1

# --- メール送信機能の設定（プロジェクトへの招待メールで使用） ---
# Resend（https://resend.com）のAPIキー。Renderなど送信SMTPポートをブロックする環境でも
# HTTPS経由で送信できるため、SMTP直接接続の代わりにこちらを使用する
RESEND_API_KEY=
# メールの送信元アドレス（未設定時は onboarding@resend.dev を使用。
# 独自ドメインをResendで検証していない場合はonboarding@resend.devのままにしておく）
MAIL_FROM=
